pipeline {

    agent { label 'bcm-bench-win' }

    parameters {
        string(name: 'TEST_IDS',       defaultValue: 'T01,T02',    description: 'IDs des tests séparés par virgule')
        string(name: 'BCM_HOST',       defaultValue: '10.20.0.25', description: 'IP RPiBCM')
        string(name: 'SIM_HOST',       defaultValue: '10.20.0.7',  description: 'IP RPiSIM')
        string(name: 'GLOBAL_TIMEOUT', defaultValue: '600',        description: 'Timeout global en secondes')
        booleanParam(name: 'FAIL_FAST', defaultValue: false,       description: 'Arrêter au premier FAIL')
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
    }

    environment {
        PYTHON    = 'C:\\Users\\PC\\AppData\\Local\\Programs\\Python\\Python311\\python.exe'
        DEPOT_DIR = 'C:\\Users\\PC\\Desktop\\depot'
    }

    stages {

        stage('Setup Python') {
            steps {
                bat """
                    if not exist "${DEPOT_DIR}\\.venv" "${PYTHON}" -m venv "${DEPOT_DIR}\\.venv"
                    "${DEPOT_DIR}\\.venv\\Scripts\\pip.exe" install --quiet redis jinja2 matplotlib
                """
            }
        }

        stage('Run Tests') {
            steps {
                bat "if not exist \"${DEPOT_DIR}\\reports\" mkdir \"${DEPOT_DIR}\\reports\""
                script {
                    def cmd = "\"${DEPOT_DIR}\\.venv\\Scripts\\python.exe\" \"${DEPOT_DIR}\\ci\\run_tests_headless.py\""
                    cmd += " --bcm-host ${params.BCM_HOST}"
                    cmd += " --sim-host ${params.SIM_HOST}"
                    cmd += " --output \"${DEPOT_DIR}\\reports\\report.html\""
                    cmd += " --json   \"${DEPOT_DIR}\\reports\\results.json\""
                    cmd += " --junit  \"${DEPOT_DIR}\\reports\\junit.xml\""
                    cmd += " --timeout ${params.GLOBAL_TIMEOUT}"
                    cmd += " --bench-id WipeWash-Bench-CI"
                    cmd += " --operator jenkins"
                    if (params.TEST_IDS?.trim())
                        cmd += " --tests ${params.TEST_IDS.trim()}"
                    if (params.FAIL_FAST)
                        cmd += " --fail-fast"

                    def exitCode = bat(script: cmd, returnStatus: true)
                    env.TEST_EXIT_CODE = "${exitCode}"

                    if (exitCode == 2) error("Erreur infrastructure — exit 2")
                    if (exitCode == 3) error("Timeout global — exit 3")

                    // Copier les rapports dans le workspace Jenkins
                    bat 'if not exist reports mkdir reports'
                    bat "copy \"${DEPOT_DIR}\\reports\\*\" reports\\"
                }
            }
        }

        stage('Publish Reports') {
            steps {
                junit allowEmptyResults: false, testResults: 'reports\\junit.xml'
                publishHTML([
                    allowMissing:          false,
                    alwaysLinkToLastBuild: true,
                    keepAll:               true,
                    reportDir:             'reports',
                    reportFiles:           'report.html',
                    reportName:            'WipeWash Test Report'
                ])
                archiveArtifacts artifacts: 'reports\\**', fingerprint: true
            }
        }

        stage('Evaluate Result') {
            steps {
                script {
                    if (env.TEST_EXIT_CODE?.toInteger() == 1) {
                        currentBuild.result = 'UNSTABLE'
                        echo "Des tests ont echoue — build UNSTABLE"
                    } else {
                        echo "Tous les tests PASS — build SUCCESS"
                    }
                }
            }
        }
    }

    post {
        always {
            echo "Build termine : ${env.BUILD_URL}"
        }
    }
}
